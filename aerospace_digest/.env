SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=your.email@gmail.com
EMAIL_TO=recipient@example.com

# ── Slack ─────────────────────────────────────────────────────────────────────
