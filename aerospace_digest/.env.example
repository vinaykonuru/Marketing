# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=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

# ── Delivery method: email | slack | file (default: file) ────────────────────
DELIVERY_METHOD=file

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: enable 2FA, then generate an App Password at
#   myaccount.google.com/apppasswords → use that as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=your.email@gmail.com
EMAIL_TO=recipient@example.com

# ── Slack ─────────────────────────────────────────────────────────────────────
# Create an incoming webhook at api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── X (Twitter) API ──────────────────────────────────────────────────────────
# Create a developer app at developer.x.com → generate a Bearer Token
# Requires Basic tier ($100/mo) or higher for search access
X_BEARER_TOKEN=your_x_bearer_token_here

# ── Optional: Serper API (enhances Google search coverage) ───────────────────
# Get a key at serper.dev (~$50/mo for 5k searches). Leave blank to skip.
# SERPER_API_KEY=your_serper_key_here
